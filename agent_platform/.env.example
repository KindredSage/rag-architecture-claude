# ┌──────────────────────────────────────────────────────────┐
# │             Agent Platform Configuration                │
# │                                                         │
# │  Copy this file to .env and fill in your values.        │
# │  All variables are prefixed with AGENT_                 │
# └──────────────────────────────────────────────────────────┘

# ── Application ──────────────────────────────────────────────
AGENT_APP_NAME="Agent Platform"
AGENT_DEBUG=false
AGENT_LOG_LEVEL=INFO
AGENT_ENVIRONMENT=development    # development | staging | production

# ── LLM Provider ────────────────────────────────────────────
AGENT_LLM_PROVIDER=openai        # openai | azure | anthropic
AGENT_LLM_MODEL=gpt-4o
AGENT_LLM_FAST_MODEL=gpt-4o-mini
AGENT_LLM_API_KEY=sk-your-key-here
AGENT_LLM_TEMPERATURE=0.0
AGENT_LLM_MAX_TOKENS=4096
AGENT_LLM_REQUEST_TIMEOUT=60

# ── ClickHouse ───────────────────────────────────────────────
AGENT_CH_HOST=localhost
AGENT_CH_PORT=8123
AGENT_CH_DATABASE=trading_db
AGENT_CH_USER=default
AGENT_CH_PASSWORD=
AGENT_CH_SECURE=false
AGENT_CH_QUERY_TIMEOUT=30
AGENT_CH_MAX_ROWS=50000

# ── PostgreSQL (Sessions & State) ────────────────────────────
AGENT_PG_HOST=localhost
AGENT_PG_PORT=5432
AGENT_PG_DATABASE=agent_platform
AGENT_PG_USER=agent_user
AGENT_PG_PASSWORD=agent_pass
AGENT_PG_POOL_MIN=5
AGENT_PG_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────
AGENT_REDIS_URL=redis://localhost:6379/0
AGENT_CACHE_TTL=300
AGENT_RATE_LIMIT_ENABLED=true
AGENT_RATE_LIMIT_DEFAULT=60/minute

# ── Email (SMTP) ─────────────────────────────────────────────
AGENT_SMTP_HOST=smtp.gmail.com
AGENT_SMTP_PORT=587
AGENT_SMTP_USER=
AGENT_SMTP_PASSWORD=
AGENT_SMTP_FROM=
AGENT_SMTP_USE_TLS=true

# ── MCP (Model Context Protocol) ────────────────────────────
AGENT_MCP_ENABLED=false
# AGENT_MCP_SERVER_URLS=["http://localhost:8081/mcp"]

# ── Storage ──────────────────────────────────────────────────
AGENT_ARTIFACT_DIR=/tmp/agent_artifacts
AGENT_MAX_ARTIFACT_SIZE_MB=50

# ── Security ─────────────────────────────────────────────────
AGENT_API_KEY=                   # empty = auth disabled
# AGENT_ALLOWED_CH_DATABASES=["trading_db"]

# ── Concurrency & Sessions ───────────────────────────────────
AGENT_MAX_CONCURRENT_RUNS=20
AGENT_RUN_TIMEOUT=300
AGENT_MAX_RETRY_PER_NODE=3
AGENT_SESSION_TTL_HOURS=24
AGENT_SESSION_CLEANUP_INTERVAL_MINUTES=30

# ── Multi-Server Deployment ──────────────────────────────────
# Each server should have a unique SERVER_ID (auto-generated if empty)
SERVER_ID=
