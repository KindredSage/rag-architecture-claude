# mTLS certs
CLIENT_CERT=/path/to/client.crt
CLIENT_KEY=/path/to/client.key
CA_CERT=/path/to/ca.crt

# Backend
BACKEND_BASE_URL=https://internal-llm.corp
TOKEN_URL=https://auth.corp/oauth/token

# Token refresh buffer (seconds before expiry to refresh)
TOKEN_EXPIRY_BUFFER=60

# This key is what OpenWebUI sends to THIS gateway
GATEWAY_API_KEY=changeme
